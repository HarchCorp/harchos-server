# HarchOS Server Configuration
# Uses HARCHOS_ prefix to avoid collision with system DATABASE_URL

# Application
HARCHOS_APP_NAME=HarchOS Server
HARCHOS_APP_VERSION=0.2.0
HARCHOS_DEBUG=true
HARCHOS_ENVIRONMENT=dev
HARCHOS_LOG_LEVEL=INFO

# Database (SQLite for local dev)
HARCHOS_DATABASE_URL=sqlite+aiosqlite:///./harchos.db
# For production PostgreSQL:
# HARCHOS_DATABASE_URL=postgresql+asyncpg://harchos:harchos@localhost:5432/harchos

# Auth
HARCHOS_SECRET_KEY=harchos-dev-secret-key-change-in-production
HARCHOS_API_KEY_PREFIX=hsk_
HARCHOS_TOKEN_PREFIX=hst_
HARCHOS_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
HARCHOS_CORS_ORIGINS=["*"]

# Pagination
HARCHOS_DEFAULT_PAGE_SIZE=20
HARCHOS_MAX_PAGE_SIZE=100

# Rate limiting
HARCHOS_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Redis (optional, for caching)
# HARCHOS_REDIS_URL=redis://localhost:6379/0

# Carbon-aware scheduling
HARCHOS_CARBON_GREEN_THRESHOLD_GCO2_KWH=200.0
HARCHOS_CARBON_CACHE_TTL_MINUTES=30
HARCHOS_CARBON_STATIC_FALLBACK=true
