# HarchOS Server Configuration
# Uses HARCHOS_ prefix to avoid collision with system DATABASE_URL
#
# All settings can be set via environment variables with HARCHOS_ prefix.
# Example: HARCHOS_DEBUG=false HARCHOS_ENVIRONMENT=production

# ============================================
# APPLICATION
# ============================================
HARCHOS_APP_NAME=HarchOS Server
HARCHOS_APP_VERSION=0.3.0
HARCHOS_DEBUG=false
HARCHOS_ENVIRONMENT=production
HARCHOS_LOG_LEVEL=INFO

# ============================================
# DATABASE — PostgreSQL (Supabase)
# ============================================
# SQLite for local dev:
HARCHOS_DATABASE_URL=sqlite+aiosqlite:///./harchos.db

# Supabase PostgreSQL (production):
# Get your connection string from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction mode" pooler for serverless/Railway:
# HARCHOS_DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Or "Session mode" for persistent servers:
# HARCHOS_DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Connection pool settings (PostgreSQL only)
HARCHOS_DB_POOL_SIZE=20
HARCHOS_DB_MAX_OVERFLOW=10
HARCHOS_DB_POOL_RECYCLE=3600

# ============================================
# AUTH — SECURITY CRITICAL
# ============================================
# Generate a secure secret key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
HARCHOS_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_PLUS_CHAR_STRING
HARCHOS_API_KEY_PREFIX=hsk_
HARCHOS_TOKEN_PREFIX=hst_
HARCHOS_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# CORS — Configure allowed origins
# ============================================
# Production: list your actual domains
# HARCHOS_CORS_ORIGINS='["https://harchcorp.vercel.app","https://api.harchos.ai"]'
# Development:
HARCHOS_CORS_ORIGINS='["http://localhost:3000","http://localhost:8000"]'

# ============================================
# PAGINATION
# ============================================
HARCHOS_DEFAULT_PAGE_SIZE=20
HARCHOS_MAX_PAGE_SIZE=100

# ============================================
# RATE LIMITING
# ============================================
HARCHOS_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================
# REDIS CACHING — Upstash (free tier)
# ============================================
# Sign up at: https://console.upstash.com
# Create a Redis database, then copy the REST URL and token:
# HARCHOS_UPSTASH_REDIS_URL=https://us1-xxxxx.upstash.io
# HARCHOS_UPSTASH_REDIS_TOKEN=your_token_here
# Traditional Redis URL (alternative):
# HARCHOS_REDIS_URL=redis://localhost:6379/0

# ============================================
# CARBON-AWARE SCHEDULING
# ============================================
# Electricity Maps API key — get a free trial at:
#   https://app.electricitymaps.com/auth/sign-up
# Academic access is free with .edu email
# HARCHOS_ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key
HARCHOS_CARBON_GREEN_THRESHOLD_GCO2_KWH=200.0
HARCHOS_CARBON_CACHE_TTL_MINUTES=30
HARCHOS_CARBON_STATIC_FALLBACK=true

# ============================================
# SECURITY HEADERS
# ============================================
HARCHOS_ENABLE_SECURITY_HEADERS=true
